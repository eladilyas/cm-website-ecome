# Production env template — copy to `.env.production` on the VPS.
# This file is tracked; never put real values in it. See docs/SECRETS.md
# for the rotation runbook.

NODE_ENV=production
NEXT_PUBLIC_SITE_URL=https://your-domain-or-ip

# When the deployment is HTTP-only (no domain yet), leave FORCE_HTTPS_CSP=0
# or unset. Flip to 1 only after TLS is terminated upstream.
FORCE_HTTPS_CSP=0

# Database — both required, distinct connection strings.
DATABASE_URL=
DIRECT_DATABASE_URL=

# Better-Auth.
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=https://your-domain-or-ip

# Cloudflare R2 — required for proof uploads + receipts in production.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=cm-website

# Resend transactional email.
RESEND_API_KEY=
EMAIL_FROM=hello@caissemanager.com
