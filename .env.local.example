# Copy this file to `.env.local` (gitignored) and fill in real values.
#
# Policy:
#   • NEVER commit real values.
#   • NEVER paste production secrets into chat — anything that has
#     appeared in a chat session is presumed leaked and must be rotated
#     before being used in production.
#   • Required-in-production keys are marked [REQUIRED-PROD]. Without
#     them, `next build` succeeds but boot will fail at first use.
#
# Rotation runbook: see docs/SECRETS.md.

# ── Runtime ───────────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Set FORCE_HTTPS_CSP=1 only when the deployment is behind HTTPS.
# Enables upgrade-insecure-requests in CSP + HSTS in response headers.
# Leave unset (or =0) on HTTP-only deployments — otherwise browsers
# will refuse to load assets.
FORCE_HTTPS_CSP=0

# ── Database — [REQUIRED-PROD] ────────────────────────────────────────
# Neon serverless Postgres (or any Postgres provider).
#   DATABASE_URL        — pooled connection (used at runtime)
#   DIRECT_DATABASE_URL — direct connection (used by `prisma migrate`)
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require
DIRECT_DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# ── Better-Auth — [REQUIRED-PROD] ─────────────────────────────────────
# Generate the secret locally: `openssl rand -base64 32`
BETTER_AUTH_SECRET=replace_with_openssl_rand_base64_32
BETTER_AUTH_URL=http://localhost:3000

# ── Cloudflare R2 (file storage) — [REQUIRED-PROD] ────────────────────
# Cloudflare dashboard → R2 → Manage API tokens.
# Account id is the prefix of your r2.cloudflarestorage.com endpoint.
R2_ACCOUNT_ID=replace_me_account_id
R2_ACCESS_KEY_ID=replace_me_access_key
R2_SECRET_ACCESS_KEY=replace_me_secret_key
R2_BUCKET=cm-website
# Optional CDN / custom-domain hostname (leave empty to use signed R2 URLs).
# R2_PUBLIC_HOSTNAME=https://files.caissemanager.com

# ── Email (Resend) — [REQUIRED-PROD] ──────────────────────────────────
RESEND_API_KEY=replace_me_resend_api_key
EMAIL_FROM=hello@caissemanager.com

# ── Observability — optional (not yet wired) ──────────────────────────
# Reserved for future Sentry / Axiom integration. Safe to leave empty.
SENTRY_DSN=
AXIOM_TOKEN=
AXIOM_DATASET=cm-platform

# ── AI Assistant — optional (not yet wired) ───────────────────────────
ANTHROPIC_API_KEY=

# ── Integrations (future phases — leave commented) ────────────────────
# ODOO_URL=
# ODOO_DB=
# CMI integration is currently stubbed; real values land when the
# CMI gateway is wired. See docs/PAYMENTS.md.
# CMI_MERCHANT_ID=
# CMI_STORE_KEY=
